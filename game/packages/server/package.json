{
  "name": "@atg/server",
  "version": "0.1.0",
  "description": "ATG — API de jeu (Fastify) + tick worker (simulation autoritaire) + migrations PostgreSQL",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "dev:api": "tsx watch src/api/index.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "start:api": "node dist/api/index.js",
    "start:worker": "node dist/worker/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "test": "vitest run test/unit",
    "test:integration": "vitest run test/integration --no-file-parallelism",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@atg/shared": "workspace:*",
    "@fastify/cookie": "^10.0.0",
    "@fastify/cors": "^10.0.0",
    "fastify": "^5.0.0",
    "pg": "^8.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
