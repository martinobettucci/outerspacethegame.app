# @spec All runtime configuration declarations in this file implement: docs/BACKLOG.md §P1 “Monorepo/app scaffolding”; docs/DAT.md §6; README.md §Environment variables; PROD_MIGRATIONS.md §“Variables/secrets à provisionner”.
# ATG — variables d'environnement (développement)
# Copier en `.env` à la racine de game/ ; jamais de secret réel dans le dépôt.
# Chaque variable : rôle, format, obligatoire ?, exemple non sensible.

# Connexion PostgreSQL (rôle : source de vérité du jeu ; format : URL libpq ;
# obligatoire ; le défaut correspond au conteneur docker-compose.dev.yml)
DATABASE_URL=postgres://atg:atg@localhost:55432/atg

# Port HTTP de l'API (rôle : écoute Fastify ; format : entier ; facultatif, défaut 8080)
API_PORT=8080

# Origine autorisée du client en dev (rôle : CORS ; format : URL ; facultatif, défaut http://localhost:5173)
CLIENT_ORIGIN=http://localhost:5173

# Secret de signature des cookies de session (rôle : intégrité des sessions ;
# format : chaîne >= 32 caractères ; obligatoire hors dev ; le défaut ci-dessous
# est un placeholder de développement, à remplacer en staging/production)
SESSION_SECRET=dev-only-secret-change-me-0123456789abcdef

# Graine de l'univers (rôle : génération déterministe des corps célestes ;
# format : chaîne hexadécimale ; obligatoire ; une valeur par environnement —
# la production aura la sienne, jamais celle de dev)
UNIVERSE_SEED=atg-dev-universe-0001

# Poivre SECRET du tirage de pocket-luck (§2.2b, Balance Round 10) : la
# chance multi-starter est tirée de HMAC(LUCK_PEPPER, email), jamais du seed
# public — empêche le farming hors-ligne des rolls chanceux (rôle : secret
# anti-abus ; format : chaîne >= 16 caractères ; obligatoire hors dev ; le
# défaut ci-dessous est un placeholder de dev, une valeur DÉDIÉE en
# staging/production ; ROTATION possible sans re-générer les poches — seule
# la géométrie reste sur UNIVERSE_SEED)
LUCK_PEPPER=dev-only-luck-pepper-change-me-0123456789

# Cadence du tick worker en millisecondes (rôle : fréquence de matérialisation
# des échéances ; format : entier ; facultatif, défaut 60000 = canon DG §0).
# `pnpm runDev` l'abaisse à 1000 par défaut pour que les actions accélérées se
# règlent sous ~1 s ; surchargeable ici ou dans l'environnement du shell.
TICK_MS=60000

# Cadence du census global de l'offre (GB §13 « admin-configurable ») :
# snapshots par jour de jeu. Entier > 0, facultatif, défaut 4 [TUNE].
CENSUS_PER_DAY=4

# Horloge de jeu — accélérateur de temps DEV/TEST (rôle : game-secondes par
# seconde réelle ; format : nombre > 0 ; facultatif, défaut 1 ; TOUJOURS 1 en
# production). Sous l'horloge unifiée (DG §1), TIME_SCALE accélère TOUTE la
# simulation de façon cohérente : minuteries d'action (chantier, retool,
# voyage), économie continue (gisements, stocks, carburant) ET cadence
# quotidienne (population, horloges de mort, grâce de colonie). Les minuteries
# SOCIALES (âge de compte, TTL d'offres manuelles, sessions) restent en temps
# réel. `pnpm runDev` force 3600 par défaut (1 s réelle = 1 h-jeu ; jour de
# jeu = 24 s) sauf surcharge dans l'environnement du shell.
TIME_SCALE=1

# Endpoints d'instrumentation de TEST (§15) : '1' active /test/grant.
# E2E uniquement — NE JAMAIS activer en staging/production.
# ATG_TEST_ENDPOINTS=1
